LANGGRAPH_URL=http://127.0.0.1:2024
# Set true only for local dev with `langgraph dev` + LangSmith Studio.
# Production (Vercel): leave false — graph runs inside the FastAPI backend.
QA_USE_LANGGRAPH_API=false

# Production (Vercel): user checks save under /tmp by default (ephemeral across cold starts).
# Optional persistent path, e.g. mounted volume on Railway/Render.
# QA_CHECKS_DATA_DIR=/data/qa-knowledge

ANTHROPIC_API_KEY=

LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=qa-agent

LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=qa-agent